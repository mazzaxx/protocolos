{
  "name": "vite-react-typescript-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "cross-env PORT=3002 node server/server.js",
    "dev:full": "concurrently \"npm run server\" \"npm run dev\"",
    "dev:local": "cross-env VITE_API_BASE_URL= concurrently \"npm run server\" \"npm run dev\"",
    "dev:cloud": "cross-env VITE_API_BASE_URL=https://sistema-protocolos-juridicos-production.up.railway.app npm run dev",
    "start": "node server/server.js",
    "start:production": "node server/server.js",
    "start:server": "cross-env PORT=3002 node server/server.js",
    "railway:start": "node server/server.js",
    "build": "vite build",
    "preview": "vite preview",
    "preview:production": "npm run build && npm run start",
    "lint": "eslint .",
    "postinstall": "echo 'Railway deploy complete'",
    "test:server": "curl http://localhost:3002 || echo 'Servidor não está rodando'",
    "debug": "concurrently \"npm run server\" \"npm run dev\" --kill-others-on-fail",
    "test:connectivity": "node server/test-connectivity.js",
    "railway:health": "curl $RAILWAY_PUBLIC_DOMAIN/health || echo 'Health check failed'"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "concurrently": "^9.2.0",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.344.0",
    "pg": "^8.16.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.7.0",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2"
  }
}
