# Configuração para Square Cloud - Plataforma de hospedagem brasileira
# Este arquivo define como a aplicação será executada na Square Cloud

# Configurações principais da aplicação
MAIN=server/server.js
MEMORY=512
VERSION=recommended

# Configurações de ambiente para produção
NODE_ENV=production

# URL base da API - será definida automaticamente pela Square Cloud
# Formato: https://seu-app.squareweb.app
VITE_API_BASE_URL=https://sistema-protocolos.squareweb.app

# Configurações do banco SQLite
# O SQLite funcionará perfeitamente na Square Cloud
DATABASE_PATH=./server/database.sqlite

# Configurações de CORS - domínio da Square Cloud
ALLOWED_ORIGINS=https://sistema-protocolos.squareweb.app

# Configurações de performance
MAX_CONNECTIONS=15
CACHE_SIZE=10000

# Configurações de logs
LOG_LEVEL=info