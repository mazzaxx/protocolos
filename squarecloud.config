# Configuração para Square Cloud - Sistema de Protocolos Jurídicos
# CONFIGURAÇÃO CORRIGIDA PARA GARANTIR BUILD AUTOMÁTICO

# Configurações principais da aplicação
MAIN=server/server.js
MEMORY=512
VERSION=recommended
DISPLAY_NAME=Sistema Protocolos Juridicos

# CRÍTICO: Comando de build deve ser executado ANTES do servidor iniciar
# Square Cloud executa este comando automaticamente durante o deploy
BUILD=npm run build

# Configurações de ambiente para produção
NODE_ENV=production

# URL base da API - será definida automaticamente pela Square Cloud
VITE_API_BASE_URL=

# Configurações do banco SQLite
DATABASE_PATH=./server/database.sqlite

# Configurações de CORS - domínio da Square Cloud
ALLOWED_ORIGINS=https://protocolos.squareweb.app

# Configurações de performance
MAX_CONNECTIONS=15
CACHE_SIZE=10000

# Configurações de logs
LOG_LEVEL=info

# SQUARE CLOUD: Configurações adicionais para garantir build
AUTO_RESTART=true