# Configuração Square Cloud - Sistema de Protocolos Jurídicos
# CONFIGURAÇÃO OTIMIZADA PARA GARANTIR FUNCIONAMENTO

# Arquivo principal - Square Cloud detectou automaticamente
MAIN=server/server.js

# Configurações de recursos
MEMORY=512
VERSION=recommended

# Nome da aplicação
DISPLAY_NAME=Sistema Protocolos Juridicos

# Configurações de ambiente para produção
NODE_ENV=production

# URL base da API - será definida automaticamente pela Square Cloud
VITE_API_BASE_URL=

# Configurações do banco SQLite
DATABASE_PATH=./server/database.sqlite

# Configurações de CORS - domínio da Square Cloud
ALLOWED_ORIGINS=https://protocolos.squareweb.app

# Configurações de performance
MAX_CONNECTIONS=15
CACHE_SIZE=10000

# Configurações de logs
LOG_LEVEL=info

# SQUARE CLOUD: Configurações adicionais
AUTO_RESTART=true