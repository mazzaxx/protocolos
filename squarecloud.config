# Configuração para Square Cloud - Sistema de Protocolos Jurídicos
# CONFIGURAÇÃO OTIMIZADA PARA MÁXIMA ESTABILIDADE

# Configurações principais da aplicação
MAIN=build-and-start.js
MEMORY=512
VERSION=recommended
DISPLAY_NAME=Sistema Protocolos Juridicos

# Configurações de ambiente para produção
NODE_ENV=production

# URL base da API - será definida automaticamente pela Square Cloud
VITE_API_BASE_URL=

# Configurações do banco SQLite otimizadas
DATABASE_PATH=./server/database.sqlite

# Configurações de CORS - domínio da Square Cloud
ALLOWED_ORIGINS=https://protocolos.squareweb.app

# Configurações de performance otimizadas
MAX_CONNECTIONS=3
CACHE_SIZE=2000

# Configurações de logs
LOG_LEVEL=info

# SQUARE CLOUD: Configurações adicionais
AUTO_RESTART=true