# Configuração para Square Cloud - Sistema Jurídico Completo
# Este arquivo configura o build do frontend + backend integrado

# CRÍTICO: Build do frontend ANTES de iniciar o servidor
BUILD=npm run build

# Configurações principais da aplicação
MAIN=server/server.js
MEMORY=512
VERSION=recommended

# Configurações de ambiente para produção
NODE_ENV=production

# URL base da API - será definida automaticamente pela Square Cloud
VITE_API_BASE_URL=

# Configurações do banco SQLite
DATABASE_PATH=./server/database.sqlite

# Configurações de CORS - domínio da Square Cloud
ALLOWED_ORIGINS=https://protocolos.squareweb.app

# Configurações de performance
MAX_CONNECTIONS=15
CACHE_SIZE=10000

# Configurações de logs
LOG_LEVEL=info