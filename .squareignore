# Arquivos e pastas que não devem ser enviados para o Square Cloud
node_modules/
.git/
.vscode/
!.vscode/settings.json
.env.local
.env.development
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.DS_Store
Thumbs.db

# Arquivos de desenvolvimento
src/
public/
!public/image.png
*.md
!README.md
.gitignore
.eslintrc.*
tsconfig*.json
vite.config.ts
postcss.config.cjs
tailwind.config.cjs

# Manter apenas os arquivos necessários para produção
!dist/
!server/
!start.js
!package.json
!squarecloud.config
!.squareignore