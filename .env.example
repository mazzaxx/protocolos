# URL do backend Railway (OBRIGATÓRIO para sincronização)
VITE_API_BASE_URL=https://sistema-protocolos-juridicos-production.up.railway.app

# PostgreSQL Database URL (Railway fornece automaticamente)
# Exemplo: postgresql://postgres:password@host:port/database
DATABASE_URL=postgresql://username:password@host:port/database

# Configurações PostgreSQL locais (apenas para desenvolvimento local)
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=protocolos_juridicos

# Configurações de produção (Railway)
NODE_ENV=production
PORT=8080